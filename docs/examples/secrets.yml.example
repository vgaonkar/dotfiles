# Secrets Configuration
# Copy this file to secrets.yml and fill in your actual values
# DO NOT commit secrets.yml to git - it's already in .gitignore

# Git configuration
git:
  user_name: "Your Name"
  user_email: "your.email@example.com"
  
  # Work vs Personal
  work_email: "your.work@company.com"

# SSH configuration
ssh:
  # Work servers
  work_hostname: "work-server.example.com"
  work_user: "your-work-username"
  
  # Personal servers
  personal_hostname: "home-server.example.com"
  personal_user: "your-personal-username"

# API keys (examples)
# aws:
#   access_key_id: "YOUR_ACCESS_KEY"
#   secret_access_key: "YOUR_SECRET_KEY"
# 
# github:
#   token: "ghp_YOUR_TOKEN"
# 
# openai:
#   api_key: "sk-YOUR_API_KEY"

# Work-specific
work:
  vpn_endpoint: "vpn.company.com"
  proxy_url: "http://proxy.company.com:8080"
