#!/usr/bin/env bash
# run_onchange_install_brew_tools.sh.tmpl
# Installs brew packages and Fisher plugins. Re-runs when tool list or plugins change.
# Hash: {{ include "dot_config/fish/fish_plugins" | sha256sum }}

set -euo pipefail

{{ if .is_container -}}
echo "[chezmoi-tools] Container environment detected — skipping tool install"
exit 0
{{- end }}

log() {
  printf '[chezmoi-tools] %s\n' "$*"
}

warn() {
  printf '[chezmoi-tools] WARN: %s\n' "$*" >&2
}

is_false() {
  case "$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')" in
    false|0|no|n) return 0 ;;
    *) return 1 ;;
  esac
}

case '{{ .chezmoi.os }}' in
  darwin|linux) ;;
  *)
    log "Skipping brew tool installation on unsupported OS: {{ .chezmoi.os }}."
    exit 0
    ;;
esac

if is_false '{{ .install_tools }}'; then
  log "Skipping brew tool installation and Fish plugin setup (install_tools=false)."
  exit 0
fi

brew_prefix="{{ template "brew-path.tmpl" . }}"
brew_bin=""

if command -v brew >/dev/null 2>&1; then
  brew_bin="$(command -v brew)"
elif [ -x "${brew_prefix}/bin/brew" ]; then
  brew_bin="${brew_prefix}/bin/brew"
fi

if [ -z "$brew_bin" ]; then
  log "Homebrew/Linuxbrew is required but was not found."
  log "Install from https://brew.sh, then re-run: chezmoi apply"
  exit 1
fi

eval "$("$brew_bin" shellenv)"

fish_bin="$("$brew_bin" --prefix)/bin/fish"
if [ ! -x "$fish_bin" ] && command -v fish >/dev/null 2>&1; then
  fish_bin="$(command -v fish)"
fi

if [ ! -x "$fish_bin" ]; then
  log "fish binary is required but was not found. Run run_once_before_00_set_default_shell first."
  exit 1
fi

DOTFILES_BREW_BIN="$brew_bin" "$fish_bin" -c '
set -l brew "$DOTFILES_BREW_BIN"
eval ($brew shellenv)
set -l pkgs starship zoxide eza bat fzf direnv atuin fd ripgrep git gh jq poppler qpdf tesseract ocrmypdf pandoc git-delta procs bottom dust gping mise

set -l missing
for pkg in $pkgs
  if $brew list --formula --versions $pkg >/dev/null 2>&1
    echo "[chezmoi-tools] Already installed: $pkg"
  else
    set missing $missing $pkg
  end
end

if test (count $missing) -eq 0
  echo "[chezmoi-tools] All default brew tools are already installed."
else
  echo "[chezmoi-tools] Installing missing tools via fish: $missing"
  $brew install $missing
end

set -l fish_plugins jorgebucaran/fisher PatrickF1/fzf.fish jethrokuan/z nickeb96/puffer-fish
if test -f ~/.config/fish/fish_plugins
  set fish_plugins (string split "\n" (string trim (cat ~/.config/fish/fish_plugins)))
  set fish_plugins (string match -r -v '^\s*#' -- $fish_plugins)
  set fish_plugins (string match -r '.' -- $fish_plugins)
end

if not type -q fisher
  if type -q curl
    echo "[chezmoi-tools] Installing fisher plugin manager"
    curl -fsSL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source
    fisher install jorgebucaran/fisher
  else
    echo "[chezmoi-tools] WARN: curl not found; skipping fisher installation."
  end
end

if type -q fisher
  echo "[chezmoi-tools] Installing/updating fish plugins: $fish_plugins"
  fisher install $fish_plugins
else
  echo "[chezmoi-tools] WARN: fisher unavailable; skipping fish plugin installation."
end
'

log "Brew tool installation complete."
