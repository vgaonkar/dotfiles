# Fish configuration template

# PATH modifications
fish_add_path ~/bin ~/.local/bin
fish_add_path $HOME/.dotnet/tools

# Manual env exports (mirrors .profile)
set -gx EDITOR vim
set -gx VISUAL vim

# SSH keychain (mirrors .bash_profile/.zprofile)
if type -q keychain
    set -l _keychain_output (bash -lc 'eval $(keychain --agents ssh --eval ~/.ssh/id_ed25519 2>/dev/null) && printf "%s\n" "$SSH_AUTH_SOCK" "$SSH_AGENT_PID"' 2>/dev/null)
    if test (count $_keychain_output) -ge 1 -a -n "$_keychain_output[1]"
        set -gx SSH_AUTH_SOCK $_keychain_output[1]
    end
    if test (count $_keychain_output) -ge 2 -a -n "$_keychain_output[2]"
        set -gx SSH_AGENT_PID $_keychain_output[2]
    end
end

# Homebrew initialization
{{ if eq .chezmoi.os "darwin" -}}
eval ({{ template "brew-path.tmpl" . }}/bin/brew shellenv)
{{ else if eq .chezmoi.os "linux" -}}
set -l _brew_prefix "{{ template "brew-path.tmpl" . }}"
if test -d $_brew_prefix
    eval ($_brew_prefix/bin/brew shellenv)
end
{{- end }}

{{ if .work_machine -}}
set -gx WORK_MACHINE true
{{ end -}}
# Start in ~/Projects when launched as a login shell from home
if status is-login; and test "$PWD" = "$HOME"
    cd ~/Projects
end

# Interactive shell configuration
if status is-interactive
    # Abbreviations
    abbr ls 'eza'
    abbr ll 'eza -al'
    abbr la 'eza -a'
    abbr l 'eza -F'
    abbr cat 'bat'
    abbr grep 'grep --color=auto'

    # Tool initializations
    if type -q zoxide; zoxide init fish | source; end
    if type -q fzf; fzf --fish | source; end
    if type -q direnv; direnv hook fish | source; end
    if type -q atuin; atuin init fish | source; end
    if type -q starship; starship init fish | source; end
end
